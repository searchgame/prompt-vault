{
    "manifest_version": 3,
    "name": "Prompt Vault",
    "version": "2.0",
    "description": "Store, search, and reuse prompts with variables and tags.",
    "permissions": [
      "storage",
      "downloads",
      "contextMenus"
    ],
    "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "host_permissions": [
      "<all_urls>"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_popup": "popup.html"
    }
}